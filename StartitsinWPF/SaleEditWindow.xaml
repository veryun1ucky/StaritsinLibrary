<Window x:Class="StartitsinWPF.SaleEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StartitsinWPF"
        mc:Ignorable="d"
        Title="Продажа — Staritsin"
        Height="520" Width="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{StaticResource BackgroundBrush}">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Style="{StaticResource WindowHeaderStyle}">
            <TextBlock x:Name="FormTitleText"
                       Text="Добавление продажи"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="20,12">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="CancelButton"
                        Content="Отмена"
                        Width="100"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Margin="0,0,8,0"
                        Click="CancelButton_Click"/>
                <Button x:Name="SaveButton"
                        Content="💾  Сохранить"
                        Width="130"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="SaveButton_Click"/>
            </StackPanel>
        </Border>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="20,16">

                <TextBlock Text="Партнёр *" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox x:Name="PartnerComboBox"
                          DisplayMemberPath="CompanyName"
                          SelectedValuePath="Id"
                          SelectionChanged="InputControl_Changed"
                          Margin="0,0,0,12"/>

                <TextBlock Text="Продукция *" Style="{StaticResource FormLabelStyle}"/>
                <ComboBox x:Name="ProductComboBox"
                          DisplayMemberPath="ProductName"
                          SelectedValuePath="Id"
                          SelectionChanged="InputControl_Changed"
                          Margin="0,0,0,12"/>

                <TextBlock Text="Количество *" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="QuantityBox"
                         ToolTip="Введите целое число больше нуля"
                         PreviewTextInput="QuantityBox_PreviewTextInput"
                         TextChanged="InputControl_Changed"
                         Margin="0,0,0,12"/>

                <TextBlock Text="Дата продажи *" Style="{StaticResource FormLabelStyle}"/>
                <DatePicker x:Name="SaleDatePicker"
                            Margin="0,0,0,12"/>

                <TextBlock Text="Комментарий" Style="{StaticResource FormLabelStyle}"/>
                <TextBox x:Name="CommentBox"
                         Height="56"
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         VerticalScrollBarVisibility="Auto"
                         Margin="0,0,0,16"/>

                <Border Padding="14"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="1"
                        Background="{StaticResource PrimaryLightBrush}"
                        CornerRadius="4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Базовая цена:" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock x:Name="BasePriceText" Text="0.00" Margin="0,2,0,10"/>

                            <TextBlock Text="Скидка партнёра:" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock x:Name="DiscountText" Text="0%" Margin="0,2,0,0"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource PrimaryDarkBrush}"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Цена продажи:" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock x:Name="UnitPriceText" Text="0.00" Margin="0,2,0,10"/>

                            <TextBlock Text="Итоговая сумма:" FontWeight="SemiBold" FontSize="12"/>
                            <TextBlock x:Name="TotalAmountText" Text="0.00" Margin="0,2,0,0"
                                       FontSize="16" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
