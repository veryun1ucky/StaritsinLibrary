<Window x:Class="StartitsinWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StartitsinWPF"
        mc:Ignorable="d"
        Title="Управление партнёрами — Staritsin"
        Height="660" Width="1080"
        MinHeight="500" MinWidth="800"
        Background="{StaticResource BackgroundBrush}">

    <Window.Resources>
        <ContextMenu x:Key="PartnerCardContextMenu">
            <MenuItem Header="✏️  Редактировать" Click="ContextMenu_Edit_Click"/>
            <Separator/>
            <MenuItem Header="🗑️  Удалить" Click="ContextMenu_Delete_Click"/>
        </ContextMenu>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Style="{StaticResource WindowHeaderStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="Партнёры компании"
                               FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBlock x:Name="PartnerCountText" FontSize="12" Foreground="#D0EDD8"/>
                </StackPanel>
                <Button Grid.Column="1"
                        Content="➕  Добавить партнёра"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="AddPartner_Click"/>
            </Grid>
        </Border>

        <Menu DockPanel.Dock="Top" Background="White" FontSize="13"
              BorderBrush="{StaticResource CardBorderBrush}" BorderThickness="0,0,0,1">
            <MenuItem Header="Меню программы">
                <MenuItem Header="➕  Добавить партнёра"       Click="AddPartner_Click"/>
                <MenuItem Header="✏️  Редактировать партнёра"  Click="EditPartner_MenuClick"/>
                <Separator/>
                <MenuItem Header="❌  Выход"                    Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="Справочники">
                <MenuItem Header="📋  Продажи" Click="Sales_Click"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="330" MinWidth="240"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Background="White">
                <Border DockPanel.Dock="Top"
                        BorderBrush="{StaticResource CardBorderBrush}"
                        BorderThickness="0,0,0,1" Padding="12,10">
                    <TextBlock Text="Список партнёров"
                               FontWeight="SemiBold" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}"/>
                </Border>

                <TextBox DockPanel.Dock="Top"
                         x:Name="SearchBox"
                         Margin="8,8,8,4"
                         TextChanged="SearchBox_TextChanged"/>

                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="8,0,8,8">
                    <ItemsControl x:Name="PartnersItemsControl">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="1" Background="White"
                                        CornerRadius="4" Margin="0,0,0,6" Padding="14,10"
                                        Cursor="Hand" Tag="{Binding}"
                                        ContextMenu="{StaticResource PartnerCardContextMenu}"
                                        MouseLeftButtonDown="PartnerCard_MouseLeftButtonDown">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource PrimaryLightBrush}"/>
                                                    <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayTitle}"
                                                       FontWeight="SemiBold" FontSize="14"
                                                       TextTrimming="CharacterEllipsis"
                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Text="{Binding DirectorName}" FontSize="12" Margin="0,2,0,0"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock Text="{Binding Phone}" FontSize="12"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                                <Run Text="Рейтинг: "/>
                                                <Run Text="{Binding Rating, Mode=OneWay}" FontWeight="SemiBold"/>
                                            </TextBlock>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DiscountText}"
                                                   FontSize="15" FontWeight="Bold"
                                                   Foreground="{StaticResource PrimaryDarkBrush}"
                                                   VerticalAlignment="Top"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{StaticResource CardBorderBrush}"/>

            <DockPanel Grid.Column="2" Margin="12">
                <TextBlock DockPanel.Dock="Top"
                           x:Name="SalesHeaderText"
                           Text="Выберите партнёра для просмотра истории реализации"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,10"/>
                <DataGrid x:Name="SalesDataGrid">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Продукция"
                                            Binding="{Binding Product.ProductName}" Width="*"/>
                        <DataGridTextColumn Header="Ед. изм."
                                            Binding="{Binding Product.Unit}" Width="70"/>
                        <DataGridTextColumn Header="Количество"
                                            Binding="{Binding Quantity, StringFormat=N0}" Width="100"/>
                        <DataGridTextColumn Header="Скидка"
                                            Binding="{Binding DiscountPercent, StringFormat={}{0}%}" Width="70"/>
                        <DataGridTextColumn Header="Цена"
                                            Binding="{Binding UnitPrice, StringFormat=N2}" Width="90"/>
                        <DataGridTextColumn Header="Сумма"
                                            Binding="{Binding TotalAmount, StringFormat=N2}" Width="100"/>
                        <DataGridTextColumn Header="Дата продажи"
                                            Binding="{Binding SaleDate, StringFormat=dd.MM.yyyy}" Width="110"/>
                    </DataGrid.Columns>
                </DataGrid>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
