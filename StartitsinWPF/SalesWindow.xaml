<Window x:Class="StartitsinWPF.SalesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:StartitsinWPF"
        mc:Ignorable="d"
        Title="Продажи — Staritsin"
        Height="600" Width="1200"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}">

    <DockPanel LastChildFill="True">

        <Border DockPanel.Dock="Top" Style="{StaticResource WindowHeaderStyle}">
            <TextBlock Text="Список продаж"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="{StaticResource CardBorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel Orientation="Horizontal">
                <Button x:Name="AddButton"
                        Width="130" Height="32"
                        Margin="0,0,8,0"
                        Content="➕  Добавить"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="AddButton_Click"/>

                <Button x:Name="EditButton"
                        Width="130" Height="32"
                        Margin="0,0,8,0"
                        Content="✏️  Изменить"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="EditButton_Click"/>

                <Button x:Name="DeleteButton"
                        Width="130" Height="32"
                        Content="🗑️  Удалить"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Click="DeleteButton_Click"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="SalesDataGrid"
                  Margin="12"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="45"/>
                <DataGridTextColumn Header="Партнёр"
                                    Binding="{Binding PartnerName}"
                                    Width="160"/>
                <DataGridTextColumn Header="Продукция"
                                    Binding="{Binding ProductName}"
                                    Width="160"/>
                <DataGridTextColumn Header="Количество"
                                    Binding="{Binding Quantity, StringFormat=N0}"
                                    Width="100"/>
                <DataGridTextColumn Header="Дата"
                                    Binding="{Binding SaleDate, StringFormat=dd.MM.yyyy}"
                                    Width="100"/>
                <DataGridTextColumn Header="Баз. цена"
                                    Binding="{Binding BasePrice, StringFormat=N2}"
                                    Width="100"/>
                <DataGridTextColumn Header="Скидка"
                                    Binding="{Binding DiscountPercent, StringFormat={}{0}%}"
                                    Width="70"/>
                <DataGridTextColumn Header="Цена продажи"
                                    Binding="{Binding UnitPrice, StringFormat=N2}"
                                    Width="110"/>
                <DataGridTextColumn Header="Сумма"
                                    Binding="{Binding TotalAmount, StringFormat=N2}"
                                    Width="110"/>
                <DataGridTextColumn Header="Комментарий"
                                    Binding="{Binding Comment}"
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

    </DockPanel>
</Window>
